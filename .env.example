# SentineLLM Configuration
ENV=development

# API Settings
# ⚠️  SECURITY: Use 127.0.0.1 (localhost only) unless you need network access
# Only use 0.0.0.0 if you understand the security implications (exposes to network)
API_HOST=127.0.0.1
API_PORT=8000
API_WORKERS=4
# ⚠️  SECURITY: Never use DEBUG=true in production
DEBUG=false

# Security
SECRET_KEY=change-me-in-production
API_KEY_HEADER=X-API-Key

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Detection Thresholds
ENTROPY_THRESHOLD=4.5
MIN_SECRET_LENGTH=16
THREAT_LEVEL_BLOCK=HIGH

# Ollama (futuro)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama2

# AWS (futuro)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
